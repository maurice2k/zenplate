{
    "name": "maurice2k/zenplate",
    "description": "Simple and fast PHP based template engine",
    "license": "LGPL-3.0",
    "type": "library",
    "authors": [
        {
            "name": "Moritz Fain",
            "email": "moritz@fain.io"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "Maurice\\Zenplate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maurice\\Zenplate\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c tests/phpunit.xml"
    }
}
